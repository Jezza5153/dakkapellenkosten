# ===========================================
# DakkapellenKosten.nl Environment Variables
# ===========================================

# Database (Neon PostgreSQL) — REQUIRED
DATABASE_URL="postgresql://user:password@host.neon.tech/dbname?sslmode=require"

# NextAuth — REQUIRED
NEXTAUTH_SECRET="openssl rand -base64 32"
NEXTAUTH_URL="http://localhost:3000"

# App URL (used in emails and Stripe redirects)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Email (Resend) — recommended, emails skipped if missing
RESEND_API_KEY=""
EMAIL_FROM="DakkapellenKosten.nl <noreply@dakkapellenkosten.nl>"
EMAIL_REPLY_TO="info@dakkapellenkosten.nl"

# Stripe — required for payments
STRIPE_SECRET_KEY=""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""
STRIPE_WEBHOOK_SECRET=""
STRIPE_PRICE_ID=""

# Cron Jobs — required for background job auth
CRON_SECRET=""

# Lead settings
LEAD_CREDIT_COST=25
MAX_COMPANIES_PER_LEAD=3

